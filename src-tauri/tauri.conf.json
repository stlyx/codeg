{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codeg",
  "version": "0.20.2-hw",
  "identifier": "app.codeg",
  "build": {
    "beforeDevCommand": "pnpm tauri:before-dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm tauri:before-build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../out": "web/"
    },
    "externalBin": ["binaries/codeg-mcp"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDN0IwRkUyRjM3QUNFMjIKUldRaXpucno0Zzk3N0M2QWRLZmdTYlMwUlo2SEo4b0ZyT0c5d3RHL2dZbzJPMzRUK2JiajNUZ1QK",
      "endpoints": [
        "https://github.com/xintaofei/codeg/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
